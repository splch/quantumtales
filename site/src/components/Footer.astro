---
import { links } from '../data/site';
---

<footer class="on-teal">
  <div class="wrap">
    <p class="ending">… and they all computed happily ever after.</p>
    <div class="cols sans">
      <span>© 2021–2026 Spencer Churchill</span>
      <a href={links.license}>CC BY-NC-SA 4.0</a>
      <a href={links.repo}>GitHub</a>
      <a href={links.email}>Contact</a>
      <a href={links.unitaryFund}>Unitary Fund</a>
    </div>
  </div>
</footer>

<style>
  footer {
    background: linear-gradient(185deg, var(--teal), var(--teal-deep));
    color: var(--cream-dim);
    padding-block: clamp(2.75rem, 6vw, 4rem);
    font-size: 1rem;
  }
  .ending {
    font-size: clamp(1.35rem, 2.6vw, 1.6rem); font-style: italic;
    color: var(--gold); text-align: center; margin-bottom: 2.25rem;
  }
  .cols {
    display: flex; flex-wrap: wrap; gap: 1rem 2.5rem;
    justify-content: center; align-items: baseline;
  }
  footer a { color: var(--cream); }
  footer a:hover { color: var(--gold); }
</style>
