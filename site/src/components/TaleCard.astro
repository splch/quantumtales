---
import { Image } from 'astro:assets';
import { links } from '../data/site';
import type { Tale } from '../data/tales';

interface Props {
  tale: Tale;
}

const { tale } = Astro.props;
const read = `${links.pdf}#page=${tale.page}`;
const colab = `https://colab.research.google.com/github/splch/quantumtales/blob/master/sources/${tale.notebook}`;
const original = `${links.repo}/blob/master/sources/${encodeURIComponent(tale.original)}`;
---

<article class="tale">
  <div class="tale-art">
    <Image src={tale.art} alt={tale.alt} widths={[300, 480, 600]} sizes="(min-width: 52rem) 12rem, 38vw" loading="lazy" />
  </div>
  <div class="tale-body">
    <h3>{tale.title}</h3>
    <p class="meta"><span class="chip">{tale.origin}</span> <span class="chip">{tale.algorithm}</span></p>
    <p>{tale.blurb}</p>
    <p class="tale-links">
      <a href={read}>Read the story</a>
      <a href={colab}>Run the code</a>
      <a href={original}>Original tale</a>
    </p>
  </div>
</article>

<style>
  .tale {
    display: grid; grid-template-columns: minmax(9rem, 38%) 1fr;
    background: var(--surface);
    border: 1px solid var(--line); border-radius: .75rem;
    overflow: hidden; box-shadow: var(--shadow);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .tale:hover { transform: translateY(-3px); box-shadow: var(--shadow-lift); }
  .tale-art { position: relative; }
  .tale-art img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tale-body { padding: 1.375rem 1.5rem 1.25rem; display: flex; flex-direction: column; gap: .625rem; }
  .tale h3 { font-size: 1.4rem; font-weight: 600; line-height: 1.2; }
  .tale .meta {
    font-family: var(--sans);
    font-size: .8125rem; font-weight: 600; letter-spacing: .02em;
    display: flex; flex-wrap: wrap; gap: .375rem;
  }
  .chip { background: var(--chip-bg); color: var(--chip-ink); border-radius: 99px; padding: .25rem .75rem; }
  .tale p { font-size: 1.0625rem; color: var(--ink-soft); }
  /* inherits the 1.0625rem paragraph size — .tale p outranks a lone class */
  .tale-links {
    margin-top: auto; padding-top: .625rem;
    font-family: var(--sans);
    display: flex; flex-wrap: wrap; gap: .375rem 1.125rem;
  }
  .tale-links a { display: inline-block; padding-block: .25rem; white-space: nowrap; }
</style>
